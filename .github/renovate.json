{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "description": "Automated dependency updates with automerge",
  "automerge": true,
  "platformAutomerge": false,
  "packageRules": [
    {
      "description": "Do not automerge spritely/actions.semantic-version (circular dependency: it uses our devcontainer image)",
      "matchPackageNames": ["spritely/actions.semantic-version"],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update ARG versions in Dockerfile with renovate comments",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) depName=(?<depName>[^\\s]+?)(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?\\s+ARG [A-Z_]+?=(?<currentValue>.+?)\\s"
      ]
    }
  ]
}
