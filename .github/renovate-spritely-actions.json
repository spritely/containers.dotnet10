{
  "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",
  "description": "Manual-only config for spritely action updates (circular dependency)",
  "enabledManagers": ["github-actions"],
  "force": {
    "packageRules": [
      {
        "description": "Only update spritely/actions.semantic-version in this manual workflow",
        "matchPackageNames": ["spritely/actions.semantic-version"],
        "enabled": true
      },
      {
        "description": "Disable everything else",
        "matchPackageNames": ["*", "!spritely/actions.semantic-version"],
        "enabled": false
      }
    ]
  }
}
