{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "description": "Manual-only config for spritely/build updates (circular dependency)",
  "enabledManagers": ["github-actions"],
  "packageRules": [
    {
      "description": "Only update spritely/build in this manual workflow",
      "matchPackageNames": ["spritely/build"],
      "enabled": true
    },
    {
      "description": "Disable everything else",
      "matchPackageNames": ["*"],
      "excludePackageNames": ["spritely/build"],
      "enabled": false
    }
  ]
}
